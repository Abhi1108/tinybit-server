{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "src/routes/**",
          "src/controllers/**",
          "src/middleware/**",
          "src/services/**",
          "src/utils/**",
          "src/config/**"
        ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "src/index.js" }]
}
